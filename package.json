{
  "name": "supplier-sync",
  "version": "1.0.0",
  "description": "External Node.js/TypeScript product sync from supplier API to Webasyst Shop-Script cloud.",
  "main": "dist/cli/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "worker": "tsx src/cli/worker.ts",
    "worker:build": "node dist/cli/worker.js",
    "admin": "tsx src/server/adminServer.ts",
    "admin:build": "node dist/server/adminServer.js",
    "check:supplier": "tsx src/cli/checkSupplierProducts.ts",
    "check:supplier:build": "node dist/cli/checkSupplierProducts.js",
    "db:migrate": "knex migrate:latest --knexfile knexfile.cjs",
    "db:rollback": "knex migrate:rollback --knexfile knexfile.cjs"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "knex": "^3.2.10",
    "mysql2": "^3.22.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}

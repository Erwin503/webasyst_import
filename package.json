{
  "name": "supplier-sync",
  "version": "1.0.0",
  "description": "External Node.js/TypeScript product sync from supplier API to Webasyst Shop-Script cloud.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check:supplier": "tsx src/checkSupplierProducts.ts",
    "check:supplier:build": "node dist/checkSupplierProducts.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
